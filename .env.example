# Copy to .env (gitignored) and adjust the paths for your machine.
# The flake dev shell auto-sources .env on entry, and direnv reloads it on
# change (see flake.nix and .envrc). Quote values that contain spaces.

# WoW 1.12.1 client Data directory (the folder full of *.MPQ archives).
# Required by test/manual_tests.py via -d.
WOW_DATA="/path/to/World of Warcraft/Data"

# Optional: pre-built navigation data (MapBuilder output directory).
# Pass to manual_tests.py via -n to skip the multi-minute Azeroth build and
# run only the query assertions.
NAV_DATA="/path/to/maps"
